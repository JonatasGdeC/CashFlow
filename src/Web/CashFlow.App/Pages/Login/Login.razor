@page "/login"
@inject CookieAuthenticationStateProvider CookieAuthenticationStateProvider

<PageTitle>CashFlow - Login</PageTitle>

<section class="app-screen login-shell">
    <div class="panel panel-pad login-panel">
        <h1 class="page-title">@FormTitle</h1>
        <p class="page-subtitle">@FormSubtitle</p>

        <div class="auth-switch" aria-label="Escolha entre entrar ou criar conta">
            <button class="auth-switch-button @(_isRegistering ? string.Empty : "active")" type="button"
                    @onclick="ShowLogin">
                Entrar
            </button>
            <button class="auth-switch-button @(_isRegistering ? "active" : string.Empty)" type="button"
                    @onclick="ShowRegister">
                Criar conta
            </button>
        </div>

        <div class="login-form">
            @if (_isRegistering)
            {
                <EditForm Model="_registerModel" OnSubmit="@HandleRegisterAsync" class="form-grid">
                    <div class="field">
                        <label for="register-name">Nome</label>
                        <InputText id="register-name" @bind-Value="_registerModel.Name" placeholder="Seu nome"/>
                    </div>
                    <div class="field">
                        <label for="register-email">Email</label>
                        <InputText id="register-email" type="email" @bind-Value="_registerModel.Email"
                                   placeholder="voce@email.com"/>
                    </div>
                    <div class="field">
                        <label for="register-password">Senha</label>
                        <InputText id="register-password" type="password" @bind-Value="_registerModel.Password"
                                   placeholder="Crie uma senha"/>
                    </div>
                    <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Criando conta..." : "Criar conta")
                    </button>
                    <button class="btn btn-ghost" type="button" @onclick="ShowLogin">Ja tenho conta</button>
                </EditForm>
            }
            else
            {
                <EditForm Model="_loginRequest" OnSubmit="@HandleLoginAsync" class="form-grid">
                    <div class="field">
                        <label for="login-email">Email</label>
                        <InputText id="login-email" @bind-Value="_loginRequest.Email" placeholder="voce@email.com"/>
                    </div>
                    <div class="field">
                        <label for="login-password">Senha</label>
                        <InputText id="login-password" type="password" @bind-Value="_loginRequest.Password"
                                   placeholder="Sua senha"/>
                    </div>
                    <button class="btn btn-primary" type="submit">
                        @(_isSubmitting ? "Entrando..." : "Entrar")
                    </button>
                </EditForm>
            }
        </div>

        @if (_listFeedbacks.Any())
        {
            <p class="form-feedback error">
                @foreach (string errorMessage in _listFeedbacks)
                {
                    @errorMessage <br/>
                }
            </p>
        }
    </div>
</section>
