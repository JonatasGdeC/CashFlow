@using CashFlow.App.Pages.Categories.Components.CategoryById
@using CashFlow.App.Utils
@using CashFlow.Communication.Response.Expense

<section class="panel panel-pad">
    <div class="section-title-row">
        <h2>Despesas recentes</h2>
        <span class="pill">@Expenses.Count itens</span>
    </div>

    @if (Expenses.Count == 0)
    {
        <p class="page-subtitle">Nenhuma despesa registrada.</p>
    }
    else
    {
        <div class="expense-list">
            @foreach (ResponseExpenseShortJson expense in Expenses)
            {
                <a class="expense-item" href="@($"expenses/{expense.Id}")">
                    <span class="expense-icon">@GetInitial.Execute(value: expense.Title)</span>
                    <span class="expense-main">
                        <strong>@expense.Title</strong>
                    </span>
                    <CategoryById CategoryId="@expense.CategoryId"/>
                    <span class="expense-amount">- @expense.Amount.ToString(format: "C")</span>
                </a>
            }
        </div>
    }
</section>
