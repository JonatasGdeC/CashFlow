<section class="panel panel-pad">
    <div class="section-title-row">
        <h2>Atualizar senha</h2>
    </div>
    <EditForm Model="_passwordModel" OnSubmit="@HandleChangePasswordAsync" class="form-grid">
        <div class="field">
            <label for="current-password">Senha atual</label>
            <InputText id="current-password" type="password" @bind-Value="_passwordModel.OldPassword"
                       disabled="@_isChangingPassword"/>
        </div>
        <div class="field">
            <label for="new-password">Nova senha</label>
            <InputText id="new-password" type="password" @bind-Value="_passwordModel.NewPassword"
                       disabled="@_isChangingPassword"/>
        </div>
        <button class="btn btn-secondary" type="submit" disabled="@_isChangingPassword">
            @(_isChangingPassword ? "Atualizando..." : "Atualizar senha")
        </button>
    </EditForm>
    
    @if (_listFeedbacks.Any())
    {
        <p class="form-feedback @(_hasErrorFeedback ? "error" : string.Empty)">
            @foreach (string feedback in _listFeedbacks)
            {
                @feedback
                <br/>
            }
        </p>
    }
</section>